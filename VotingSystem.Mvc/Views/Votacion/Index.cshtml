@{
    Layout = "_LayoutVotacion";
}
<h2>Ingrese su código</h2>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<form asp-action="Validar" method="post">
<input name="codigo"
       class="form-control mb-2 text-center fw-bold input-codigo"
       autocomplete="off"
       autocorrect="off"
       autocapitalize="off"
       spellcheck="false"
       autofocus />
       <button class="btn btn-primary">Continuar</button>
</form>