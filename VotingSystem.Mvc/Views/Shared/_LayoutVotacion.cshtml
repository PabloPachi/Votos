<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <title>Votación</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
            body {
                background-color: #f5f5f5;
                text-align: center;
            }

            .contenedor {
                margin-top: 50px;
            }

            .btn-votar {
                width: 200px;
                height: 60px;
                font-size: 20px;
            }

            .input-codigo {
                font-size: 58px;
                height: 90px;
                letter-spacing: 2px;
        
            }

            .contenedor-candidatos {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
                gap: 20px;
                padding: 20px;
            }

            .card-candidato {
                background: white;
                border-radius: 12px;
                padding: 15px;
                box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
                text-align: center;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                height: 100%;
            }

            .img-container {
                height: 180px;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .img-container img {
                max-height: 100%;
                max-width: 100%;
                object-fit: contain;
                border-radius: 8px;
            }

            .info {
                margin-top: 10px;
                min-height: 80px;
            }

            .info h4 {
                font-size: 20px;
                font-weight: bold;
                margin-bottom: 5px;
            }

            .info p {
                font-size: 16px;
                color: gray;
            }

            .btn-votar {
                margin-top: 15px;
                height: 60px;
                font-size: 20px;
                font-weight: bold;
                border-radius: 10px;
                background-color: #28a745;
                color: white;
                border: none;
                transition: 0.2s;
            }

            .btn-votar:hover {
                background-color: #218838;
                transform: scale(1.05);
            }

            .btn-votar:active {
                transform: scale(0.95);
            }

            #splash {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: white;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                z-index: 9999;
            }

            .spinner {
                width: 60px;
                height: 60px;
                border: 6px solid #ddd;
                border-top: 6px solid #007bff;
                border-radius: 50%;
                animation: spin 1s linear infinite;
            }
    </style>
</head>

<body>
    <div id="splash">
        <div class="spinner"></div>
        <p>Cargando...</p>
    </div>
    <div class="contenedor">
        @RenderBody()
    </div>
    <script>
            // 🔵 Ocultar splash cuando carga la página
            window.onload = function () {
                document.getElementById("splash").style.display = "none";
            };

            // 🔥 Mostrar splash en navegación
            document.addEventListener("DOMContentLoaded", function () {

                // 👉 Links
                document.querySelectorAll("a").forEach(link => {
                    link.addEventListener("click", function () {
                        document.getElementById("splash").style.display = "flex";
                    });
                });

                // 👉 Formularios
                document.querySelectorAll("form").forEach(form => {
                    form.addEventListener("submit", function () {
                        document.getElementById("splash").style.display = "flex";
                    });
                });

            });
    </script>
</body>

</html>