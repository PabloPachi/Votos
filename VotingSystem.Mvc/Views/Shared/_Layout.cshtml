<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Votación</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VotingSystem.Mvc.styles.css" asp-append-version="true" />
</head>

<body>
    <div id="splash">
        <div class="spinner"></div>
        <p>Cargando...</p>
    </div>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Votación</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Candidatos"
                               asp-action="Index">Candidatos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Votantes"
                               asp-action="Index">Votantes</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Resultados"
                               asp-action="Index">Resultados</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Votacion"
                               asp-action="Index">Votación</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Votación - PPC
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
            window.onload = function () {
                document.getElementById("splash").style.display = "none";
            };

            document.addEventListener("DOMContentLoaded", function () {

                // 👉 LINKS
                document.querySelectorAll("a").forEach(link => {
                    link.addEventListener("click", function () {

                        // ❌ evitar splash
                        if (this.classList.contains("no-splash")) return;

                        if (this.getAttribute("href") === "#") return;

                        document.getElementById("splash").style.display = "flex";
                    });
                });

                // 👉 FORMULARIOS
                document.querySelectorAll("form").forEach(form => {
                    form.addEventListener("submit", function () {

                        // ❌ evitar splash
                        if (this.classList.contains("no-splash")) return;

                        document.getElementById("splash").style.display = "flex";
                    });
                });

            });
    </script>
</body>

</html>
